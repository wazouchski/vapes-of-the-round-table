<script>
  function otLoadSource(fileName,isCSS = false) {
        const fileUrl  = isCSS ?  otGetResouceFile(fileName, isCSS) : otGetResouceFile(fileName)
        isCSS ? otLoadCSS(fileUrl) : otLoadScript(fileUrl)
    }

    function otLoadScript(url, callback = () => {}) {
      var script = document.createElement('script');
      script.type = 'text/javascript';
      script.src = url;
      script.defer = true;

      if (script.readyState) {  // IE
          script.onreadystatechange = function() {
              if (script.readyState == 'loaded' || script.readyState == 'complete') {
                  script.onreadystatechange = null;
                  callback();
              }
          };
      } else {  // Other browsers
          script.onload = function() {
              callback();
          };
      }

      document.getElementsByTagName('head')[0].appendChild(script);
    }
    function otLoadCSS(href) {
        const cssLink = document.createElement("link");
        cssLink.href = href;
        cssLink.rel = "stylesheet";
        cssLink.type = "text/css";

        const body = document.getElementsByTagName("body")[0];
        body.appendChild(cssLink);
    }

    function otGetResouceFile(fileName, isCSS) {
      const listFile = [{
        key: 'full',
        url: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/full.js",
        css: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/full.css",
      },{
        key: 'corner',
        url: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/corner.js",
        css: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/corner.css",
      },{
        key: 'sidebar',
        url: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/sidebar.js",
        css: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/sidebar.css",
      },{
        key: 'center',
        url: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/center.js",
        css: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/center.css",
      },
      {
        key: 'custom',
        url: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/custom.js",
        css: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/custom.css",
      },
      {
        key: 'main',
        url: "",
        css: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/main.css",
      },
      {
        key: 'dataRequest',
        url: "https://cdn.shopify.com/extensions/019d470a-f2f8-7cd9-94cf-f11da9640e17/consentik-ex-202604011016/assets/dataRequest.js",
      },
    ]
    const fileURL = listFile.find(item => item.key === fileName)
    if(isCSS)  {
      return fileURL.css
    }
    return fileURL.url
    }
</script>
