				<div class="elementor-element elementor-element-0c37cb8 elementor-widget elementor-widget-html" data-id="0c37cb8" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<script>
document.addEventListener("DOMContentLoaded", function () {
  function removeFreshchat() {
    const el = document.querySelector('#ember3.content-vp.ember-view');
    if (el) {
      el.remove();
    }
  }

  // Try immediately
  removeFreshchat();

  // Watch for dynamic insertion
  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
        removeFreshchat();
      }
    }
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
});
</script>
