file_to_upload_text":"Or drop file to upload"},"custom_fonts":null,"primary_locale":null},"enable":1,"enableInCart":1,"enableDiscount":0,"enableMiniCart":1,"enableAddOns":1,"enableFeaturedProduct":0,"enableDisplayProductPrice":1,"apiDomain":"https://api-option.optis.me","proxySubpath":"bssoptionsets","optionSetTotalKey":0,"storefrontAccessToken":"2fb9e094fb7e52124e2f68a3fca73d7c","isUseMetaobject":true,"apiVersion":"2025-10","shop":"tbqv0f-ck.myshopify.com","canUseStorefrontFeature":false}
