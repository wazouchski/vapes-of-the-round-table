//$acs("[name=currencies]:visible").css("line-height",$acs(".pick_currency").parent(":visible").height());

  $acs("#currencies").niceSelect();
  $acs("#currencies1").niceSelect();
  $acs("#currencies2").niceSelect();

  onetimecallflag = false;
  }
}






