<script type="text/javascript">

window.shopify_supported_currencies = "EUR USD ";

window.mlvShopMainCurrency = 'EUR';
window.mlvShopName = 'INHALE Vaporizers';
window.mlvShopCurrency = 'EUR';
window.mlvMoneyWithCurrencyFormat = "€{{amount_with_comma_separator}} EUR";
window.mlvMoneyFormat = "€{{amount_with_comma_separator}}";
window.mlvCartCurrencyISOCode = 'EUR';

var mlvForm = '<form method="post" action="/cart/update" id="currency_form" accept-charset="UTF-8" class="currency-selector small--hide" enctype="multipart/form-data"><input type="hidden" name="form_type" value="currency" /><input type="hidden" name="utf8" value="✓" /><input type="hidden" name="return_to" value="/404" /><input type="hidden" name="currency" value="CurrencyDrop"></form>';

document.addEventListener("DOMContentLoaded", function(event) { 
  document.body.insertAdjacentHTML( 'beforeend', mlvForm );
});
</script>


