<style>
  header-drawer {
    justify-self: start;
  }

  .header__heading-logo {
    max-width: 120px;
    min-width: 80px;
  }

  /* Logo scale-down animation removed */

  

  /* Move hamburger menu to right on mobile/tablet */
  @media screen and (max-width: 1279px) {
    .header {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
    }
    
    header-drawer {
      justify-self: end !important;
      margin-left: auto !important;
      order: 999;
    }
    
    .header__heading {
      justify-self: start !important;
      margin-right: auto !important;
      order: 1;
    }
    
    .header__icons {
      order: 2;
      margin-left: auto;
    }
  }

  @media (min-width: 1280px) {
    header-drawer {
      display: none;
    }
    .header__heading-logo {
      max-width: 100px;
    }
  }

  @media (min-width: 1280px) {
    .header__inline-menu {
      display: block;
    }

    .header--top-center .header__inline-menu {
      justify-self: center;
    }

    .header--top-center .header__inline-menu > .list-menu--inline {
      justify-content: center;
    }

    .header--middle-left .header__inline-menu {
      margin-left: 0;
    }
  }

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

.select2-container--default .select2-results__option[aria-selected=true] {
    background-color: white !important;
    height: 57px !important;
}
.select2-container--default .select2-results__option--highlighted[aria-selected] {
    background-color: #5897fb !important;
    color: white;
}
/* Country Selection - Circle Icon Style */
.country_selection {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 40px !important;
}

@media screen and (max-width: 600px) {
  .country_selection {
    width: 40px !important;
    min-width: 40px !important;
    max-width: 40px !important;
  }
}

.country_selection label {
  display: none;
}

.select2-container {
  width: 40px !important;
  height: 40px !important;
}

span.select2-selection.select2-selection--single {
  background: rgba(0, 0, 0, 0.3) !important;
  border: none !important;
  height: 40px !important;
  width: 40px !important;
  border-radius: 50% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
  position: relative;
}

span.select2-selection.select2-selection--single::before {
  content: "";
  position: absolute;
  inset: 0;
  padding: 2px;
  border-radius: 50%;
  background: linear-gradient(1deg, rgba(243, 108, 62, 0.2) 0%, rgba(243, 108, 62, 1) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask-composite: exclude;
  pointer-events: none;
  z-index: -1;
}

.country_selection img {
  width: 20px !important;
  height: 20px !important;
  border-radius: 50% !important;
  border: none !important;
  object-fit: cover;
}

span#select2-id_select2_example-container {
  width: 100% !important;
  height: 100% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
}

span#select2-id_select2_example-container > div {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 100% !important;
  height: 100% !important;
}

span#select2-id_select2_example-container > div > p {
  display: none !important;
}

.select2-container--default .select2-selection--single .select2-selection__arrow {
  display: none !important;
}

.select2-container--default .select2-selection--single .select2-selection__arrow b {
  display: none !important;
}

span.select2-results img {
  height: 20px !important;
  border-radius: 50% !important;
}

ul#select2-id_select2_example-results li {
  height: auto !important;
}

ul#select2-id_select2_example-results > li > div {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

ul#select2-id_select2_example-results > li > div > p {
  margin: 0 0 0 15px !important;
  font-size: 16px !important;
}

ul#select2-id_select2_example-results > li {
  align-items: center;
  display: flex;
  justify-content: space-between;
  border-bottom: 1px solid #f5f5f5;
}

/* Make dropdown wider when opened */
.select2-dropdown {
  min-width: 200px !important;
  width: auto !important;
  max-width: calc(100vw - 40px) !important;
}

.select2-results {
  min-width: 200px !important;
  width: auto !important;
}

.select2-container--open .select2-dropdown {
  left: auto !important;
  right: 0 !important;
}

.select2-container--open.select2-container--below .select2-dropdown {
  margin-top: 5px !important;
}

/* Ensure dropdown aligns with icon on right side */
.country_selection .select2-container--open .select2-dropdown {
  right: 0 !important;
  left: auto !important;
}

@media screen and (max-width: 768px) {
  .select2-dropdown {
    max-width: calc(100vw - 20px) !important;
  }
  
  .country_selection .select2-container--open .select2-dropdown {
    right: 10px !important;
    left: auto !important;
  }
}
@media screen and (min-width: 990px){
.header--middle-left {
    grid-template-columns: 1fr auto 1fr auto;
    -webkit-column-gap: 2rem;
    -moz-column-gap: 2rem;
    column-gap: 2rem;
    display: grid;
}
}

/* Header Account and Cart Icon Styles */
.header__icon-circle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  min-width: 40px;
  min-height: 40px;
  max-width: 40px;
  max-height: 40px;
  border: none;
  border-radius: 50%;
  padding: 0;
  flex-shrink: 0;
  box-sizing: border-box;
  aspect-ratio: 1 / 1;
  position: relative;
  background: rgba(0, 0, 0, 0.3);
}

.header__icon-circle::before {
  content: "";
  position: absolute;
  inset: 0;
  padding: 2px;
  border-radius: 50%;
  background: linear-gradient(1deg, rgba(243, 108, 62, 0.2) 0%, rgba(243, 108, 62, 1) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask-composite: exclude;
  pointer-events: none;
  z-index: -1;
}

.header__icon-circle-count {
  z-index: 9999;
  position: absolute;
  top: -20px;
  right: 0px;
  background: #ff6e07;
  color: #ffffff;
  font-size: 12px;
  line-height: 1;
  padding: 4px 6px;
  border-radius: 999px;
  display: none;
  min-width: 20px;
  text-align: center;
}

.header__icon-svg {
  width: 20px;
  height: 20px;
  min-width: 20px;
  min-height: 20px;
  max-width: 20px;
  max-height: 20px;
  display: block;
  object-fit: contain;
  flex-shrink: 0;
}

.header__account-cart {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.header__icon--account,
.header__icon--cart {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* Header Search Input Styles */
.header__search {
  display: flex;
  align-items: center;
  margin-right: 1rem;
}

.header__search-form-inline {
  display: flex;
  align-items: center;
  position: relative;
  outline: none;
}

.header__search-form-inline:focus {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-form-inline:focus-within {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-close {
  display: none !important;
}

/* Ensure close button never shows on desktop */
@media screen and (min-width: 601px) {
  .header__search-close {
    display: none !important;
  }
}

.header__search-field {
  display: flex;
  align-items: center;
  position: relative;
  background: rgba(0, 0, 0, 0.3);
  border: none;
  border-radius: 500px;
  padding: 0;
}

.header__search-field::before {
  content: "";
  position: absolute;
  inset: 0;
  padding: 2px;
  border-radius: 500px;
  background: linear-gradient(1deg, rgba(243, 108, 62, 0.2) 0%, rgba(243, 108, 62, 1) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask-composite: exclude;
  pointer-events: none;
  z-index: -1;
}

.header__search-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  padding: 8px 12px;
  cursor: pointer;
  color: white;
  flex-shrink: 0;
  outline: none;
}

.header__search-icon-button:focus {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-icon-button:focus-visible {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-icon-button svg {
  width: 20px;
  height: 20px;
}

.header__search-input {
  background: transparent;
  border: none;
  color: white;
  padding: 8px 12px 8px 0;
  font-size: 14px;
  outline: none;
  min-width: 200px;
  flex: 1;
}

.header__search-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.header__search-input:focus {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-input:focus-visible {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-field:focus-within {
  outline: none;
  border: none;
  box-shadow: none;
}

.header__search-field:focus-within::before {
  outline: none;
  border: none;
  box-shadow: none;
}

@media screen and (max-width: 749px) {
  .header__search-input {
    min-width: 150px;
  }
}

/* Mobile search - hide input, show icon only below 600px */
@media screen and (max-width: 600px) {
  .header__heading-logo {
    width: 80px !important;
    min-width: 80px !important;
    max-width: 80px !important;
  }
  
  .header__search {
    justify-content: flex-end;
  }
  
  .header__search-input {
    display: none !important;
  }
  
  .header__search-submit {
    display: none !important;
  }
  
  .header__search-field {
    width: 40px !important;
    height: 40px !important;
    min-width: 40px !important;
    max-width: 40px !important;
    padding: 0 !important;
  }
  
  .header__search-icon-button {
    width: 100% !important;
    height: 100% !important;
    padding: 0 !important;
  }
  
  .header__search-close {
    display: none !important;
  }
  
  /* When search is active, show full search and hide other elements */
  .header.search-active {
    flex-wrap: nowrap;
  }
  
  .header.search-active .header__heading {
    display: none !important;
  }
  
  .header.search-active .header__heading-logo {
    width: 60px !important;
    min-width: 60px !important;
    max-width: 60px !important;
  }
  
  .header.search-active .header__account-cart,
  .header.search-active header-drawer,
  .header.search-active .country_selection {
    display: none !important;
  }
  
  .header.search-active .header__icons {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }
  
  .header.search-active .header__search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
    justify-content: center;
    margin-right: 0;
  }
  
  .header.search-active .header__search-form-inline {
    display: flex;
    align-items: center;
    gap: 0;
    flex: 1;
    min-width: 0;
  }
  
  .header.search-active .header__search-input {
    display: block !important;
    min-width: 0;
    flex: 1;
    padding: 8px 12px 8px 0 !important;
  }
  
  .header.search-active .header__search-submit {
    display: none !important;
  }
  
  .header.search-active .header__search-field {
    width: auto !important;
    min-width: 0 !important;
    flex: 1 !important;
    max-width: none !important;
    padding: 0 !important;
    display: flex !important;
    align-items: center !important;
  }
  
  .header.search-active .header__search-toggle {
    display: flex !important;
    width: auto !important;
    height: auto !important;
    padding: 8px 12px !important;
    flex-shrink: 0;
  }
  
  .header.search-active .header__search-close {
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: transparent;
    border: none;
    color: white;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
  }
  
  .header.search-active .header__search-close svg {
    width: 20px;
    height: 20px;
  }
}

/* Light mode: white background, black text */
.header-wrapper--light {
  background: rgba(255, 255, 255, 0.80);
  backdrop-filter: blur(5px) brightness(100%);
  -webkit-backdrop-filter: blur(5px) brightness(100%);
}

/* Text elements - black text */
.header-wrapper--light .header__menu-item,
.header-wrapper--light .header__menu-item span,
.header-wrapper--light .header__active-menu-item,
.header-wrapper--light .header__heading-link,
.header-wrapper--light .header__heading-link span,
.header-wrapper--light a,
.header-wrapper--light .menu-drawer__menu-item {
  color: #000 !important;
}

/* Search field - white background, black text */
.header-wrapper--light .header__search-field {
  background: transparent !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}

.header-wrapper--light .header__search-input {
  color: #000 !important;
}

.header-wrapper--light .header__search-input::placeholder {
  color: rgba(0, 0, 0, 0.7) !important;
}

.header-wrapper--light .header__search-icon-button {
  color: #000 !important;
}

.header-wrapper--light .header__search-icon-button svg path {
  stroke: #000 !important;
}

/* Icon circles - white background */
.header-wrapper--light .header__icon-circle {
  background: transparent !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}

/* Country selector - white background */
.header-wrapper--light .country_selection span.select2-selection.select2-selection--single {
  background: transparent !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}

/* Menu drawer items */
.header-wrapper--light .menu-drawer__menu-item {
  color: #000 !important;
}

.header-wrapper--light .menu-drawer__menu-item--active {
  color: #000 !important;
}

/* SVG icons - black */
.header-wrapper--light .header__icon-svg {
  filter: brightness(0);
}

/* Close icon in search */
.header-wrapper--light .header__search-close {
  color: #000 !important;
}

.header-wrapper--light .header__search-close svg path {
  stroke: #000 !important;
}

/* Hamburger menu icon */
.header-wrapper--light .header__icon--menu svg {
  color: #000 !important;
}

.header-wrapper--light .header__icon--menu svg path {
  stroke: #000 !important;
  fill: #000 !important;
}

/* Submenu items */
.header-wrapper--light .header__submenu .header__menu-item {
  color: #000 !important;
}

.header-wrapper--light .header__submenu .list-menu__item--active {
  color: #000 !important;
}

/* Dropdown/submenu backgrounds - white */
.header-wrapper--light .header__submenu,
.header-wrapper--light .header__submenu.list-menu--disclosure {
  background: rgb(255, 255, 255, 0.9) !important;
}

/* Menu drawer background - white */
.header-wrapper--light #menu-drawer {
  background: rgb(255, 255, 255, 0.8) !important;
}

/* Menu drawer submenu backgrounds - white */
.header-wrapper--light .menu-drawer__submenu,
.header-wrapper--light .menu-drawer__submenu.has-submenu {
  background: rgb(255, 255, 255, 0.8) !important;
}

/* Mega menu active items */
.header-wrapper--light .header-mega-menu__active-menu-item {
  color: #000 !important;
}

/* Caret icons */
.header-wrapper--light .icon-caret svg {
  color: #000 !important;
}

.header-wrapper--light .icon-caret svg path {
  stroke: #000 !important;
  fill: #000 !important;
}

/* All SVG icons in header - override white strokes */
.header-wrapper--light svg path[stroke="white"],
.header-wrapper--light svg path[stroke="#fff"],
.header-wrapper--light svg path[stroke="#ffffff"] {
  stroke: #000 !important;
}

.header-wrapper--light svg[stroke="white"],
.header-wrapper--light svg[stroke="#fff"],
.header-wrapper--light svg[stroke="#ffffff"] {
  stroke: #000 !important;
}

/* Search icon SVG - override inline white stroke */
.header-wrapper--light .icon-search path {
  stroke: #000 !important;
}

/* Knockout: View all – black arrow by default, white arrow + white text on hover */
.header-wrapper--light .header-menu-item-view-all {
  color: #000 !important;
}
.header-wrapper--light .header-menu-item-view-all .header-menu-item-view-all__arrow--white,
.header-wrapper--light .header-menu-item-view-all .header-menu-item-view-all__arrow--highlight {
  display: none !important;
}
.header-wrapper--light .header-menu-item-view-all .header-menu-item-view-all__arrow--black {
  display: inline-block !important;
}
.header-wrapper--light .header-menu-item-view-all:hover,
.header-wrapper--light .header-menu-item-view-all:hover span {
  color: #fff !important;
}
.header-wrapper--light .header-menu-item-view-all:hover {
  background: #f36c3e !important;
}
.header-wrapper--light .header-menu-item-view-all:hover .header-menu-item-view-all__arrow--white {
  display: inline-block !important;
}
.header-wrapper--light .header-menu-item-view-all:hover .header-menu-item-view-all__arrow--highlight,
.header-wrapper--light .header-menu-item-view-all:hover .header-menu-item-view-all__arrow--black {
  display: none !important;
}

/* Knockout: submenu links – black arrow by default, highlight orange arrow + orange text on hover */
.header-wrapper--light .header__submenu-link {
  color: #000 !important;
}
.header-wrapper--light .header__submenu-link .header__submenu-link-arrow--white,
.header-wrapper--light .header__submenu-link .header__submenu-link-arrow--hover {
  display: none !important;
}
.header-wrapper--light .header__submenu-link .header__submenu-link-arrow--black {
  display: inline-block !important;
}
.header-wrapper--light .header__submenu-link:hover {
  color: #f36c3e !important;
}
.header-wrapper--light .header__submenu-link:hover .header__submenu-link-arrow--white,
.header-wrapper--light .header__submenu-link:hover .header__submenu-link-arrow--black {
  display: none !important;
}
.header-wrapper--light .header__submenu-link:hover .header__submenu-link-arrow--hover {
  display: inline-block !important;
}

/* Knockout: nested group title (Extract Vaporizers, Dry Herb) – black text */
.header-wrapper--light #menu-drawer .menu-drawer__nested-group-title {
  color: #000 !important;
}
