<script>
function custom_template(obj){
  var data = $(obj.element).data();
    var text = $(obj.element).text();
      if(data && data['img_src']){
          img_src = data['img_src'];
              template = $("<div><img src=\"" + img_src + "\"/><p style=\"font-size:14pt;text-align:center;margin: -40px 5px 11px 58px;\">" + text + "</p></div>");
                  return template;
                    }
                    }
                    var options = {
                      'templateSelection': custom_template,
                        'templateResult': custom_template,
                        }
                        
                        $('#id_select2_example').select2(options);
                        $('.select2-container--default .select2-selection--single').css({'height': '40px', 'width': '40px'});
                        
                        $('#id_select2_example').on('change', function(){
                          $(this).addClass('flag_changed');
                            var selected_country = $('#select2-id_select2_example-container').attr('title');
                              if(selected_country == 'USA'){
                                  window.location.href = 'https://davincivaporizer.com?c=1';
                                    } else if(selected_country == 'Canada'){
                                        window.location.href = 'https://www.davincivaporizer.ca?c=1';
                                          } else if(selected_country == 'Europe'){
                                              window.location.href = 'https://davincivaporizers.eu?c=1';
                                                } 
                                                });
                                                
                                                $(document).on('click', 'details[id^="Details-HeaderMenu-"] > summary', function(e) {
                                                  if (window.innerWidth < 1280) return;
                                                    var $thisDetails = $(this).closest('details[id^="Details-HeaderMenu-"]');
                                                      $('details[id^="Details-HeaderMenu-"]').not($thisDetails).removeAttr('open');
                                                      });
                                                      
                                                      (function() {
                                                        var desktop = window.matchMedia('(min-width: 1280px)');
                                                          var leaveDelay = 150;
                                                          
                                                            function initHeaderMenuHover() {
                                                                document.querySelectorAll('header-menu').forEach(function(wrapper) {
                                                                      var details = wrapper.querySelector('details[id^="Details-HeaderMenu-"]');
                                                                            if (!details) return;
                                                                                  if (wrapper._headerMenuHover) return;
                                                                                        wrapper._headerMenuHover = true;
                                                                                        
                                                                                              var closeTimer;
                                                                                                    wrapper.addEventListener('mouseenter', function() {
                                                                                                            if (!desktop.matches) return;
                                                                                                                    clearTimeout(closeTimer);
                                                                                                                            document.querySelectorAll('details[id^="Details-HeaderMenu-"]').forEach(function(d) {
                                                                                                                                      if (d !== details) d.removeAttribute('open');
                                                                                                                                                var sum = d.querySelector('summary');
                                                                                                                                                          if (sum) sum.setAttribute('aria-expanded', d === details);
                                                                                                                                                                  });
                                                                                                                                                                          details.setAttribute('open', '');
                                                                                                                                                                                  var s = details.querySelector('summary');
                                                                                                                                                                                          if (s) s.setAttribute('aria-expanded', 'true');
                                                                                                                                                                                                });
                                                                                                                                                                                                      wrapper.addEventListener('mouseleave', function() {
                                                                                                                                                                                                              if (!desktop.matches) return;
                                                                                                                                                                                                                      closeTimer = setTimeout(function() {
                                                                                                                                                                                                                                details.removeAttribute('open');
                                                                                                                                                                                                                                          var s = details.querySelector('summary');
                                                                                                                                                                                                                                                    if (s) s.setAttribute('aria-expanded', 'false');
                                                                                                                                                                                                                                                            }, leaveDelay);
                                                                                                                                                                                                                                                                  });
                                                                                                                                                                                                                                                                      });
                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                          document.querySelectorAll('details[id^="Details-HeaderMenu-"] > summary').forEach(function(summary) {
                                                                                                                                                                                                                                                                                if (summary._headerMenuSummaryPrevent) return;
                                                                                                                                                                                                                                                                                      summary._headerMenuSummaryPrevent = true;
                                                                                                                                                                                                                                                                                            summary.addEventListener('click', function(e) {
                                                                                                                                                                                                                                                                                                    if (desktop.matches) e.preventDefault();
                                                                                                                                                                                                                                                                                                          });
                                                                                                                                                                                                                                                                                                              });
                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                  if (document.readyState === 'loading') {
                                                                                                                                                                                                                                                                                                                      document.addEventListener('DOMContentLoaded', initHeaderMenuHover);
                                                                                                                                                                                                                                                                                                                        } else {
                                                                                                                                                                                                                                                                                                                            initHeaderMenuHover();
                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                desktop.addEventListener('change', function() {
                                                                                                                                                                                                                                                                                                                                    if (!desktop.matches) {
                                                                                                                                                                                                                                                                                                                                          document.querySelectorAll('details[id^="Details-HeaderMenu-"]').forEach(function(d) {
                                                                                                                                                                                                                                                                                                                                                  d.removeAttribute('open');
                                                                                                                                                                                                                                                                                                                                                          var s = d.querySelector('summary');
                                                                                                                                                                                                                                                                                                                                                                  if (s) s.setAttribute('aria-expanded', 'false');
                                                                                                                                                                                                                                                                                                                                                                        });
                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                              });
                                                                                                                                                                                                                                                                                                                                                                              })();
                                                                                                                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                                                                                                              $(document).on('click', '#menu-drawer details[id^="Details-menu-drawer-menu-item-"] > summary', function() {
                                                                                                                                                                                                                                                                                                                                                                                var $thisDetails = $(this).closest('details[id^="Details-menu-drawer-menu-item-"]');
                                                                                                                                                                                                                                                                                                                                                                                  $('#menu-drawer details[id^="Details-menu-drawer-menu-item-"]').not($thisDetails).removeAttr('open');
                                                                                                                                                                                                                                                                                                                                                                                  });
                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                  function initMobileSearch() {
                                                                                                                                                                                                                                                                                                                                                                                    var $header = $('.header');
                                                                                                                                                                                                                                                                                                                                                                                      var $searchToggle = $('.header__search-toggle');
                                                                                                                                                                                                                                                                                                                                                                                        var $searchClose = $('.header__search-close');
                                                                                                                                                                                                                                                                                                                                                                                          var $searchInput = $('.header__search-input');
                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                              $searchToggle.off('click.mobileSearch');
                                                                                                                                                                                                                                                                                                                                                                                                $searchClose.off('click.mobileSearch');
                                                                                                                                                                                                                                                                                                                                                                                                  $(document).off('keydown.mobileSearch');
                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                      if (window.innerWidth <= 600) {
                                                                                                                                                                                                                                                                                                                                                                                                          $searchToggle.on('click.mobileSearch', function(e) {
                                                                                                                                                                                                                                                                                                                                                                                                                e.preventDefault();
                                                                                                                                                                                                                                                                                                                                                                                                                      e.stopPropagation();
                                                                                                                                                                                                                                                                                                                                                                                                                            $header.addClass('search-active');
                                                                                                                                                                                                                                                                                                                                                                                                                                  setTimeout(function() { $searchInput.focus(); }, 100);
                                                                                                                                                                                                                                                                                                                                                                                                                                      });
                                                                                                                                                                                                                                                                                                                                                                                                                                          $searchClose.on('click.mobileSearch', function(e) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                e.preventDefault();
                                                                                                                                                                                                                                                                                                                                                                                                                                                      e.stopPropagation();
                                                                                                                                                                                                                                                                                                                                                                                                                                                            $header.removeClass('search-active');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  $searchInput.val('');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        $searchInput.blur();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                $(document).on('keydown.mobileSearch', function(e) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      if (e.key === 'Escape' && $header.hasClass('search-active')) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              $header.removeClass('search-active');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      $searchInput.val('');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              $searchInput.blur();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          } else {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              $header.removeClass('search-active');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                $(document).ready(function() { initMobileSearch(); });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                $(window).on('resize', function() { initMobileSearch(); });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </script>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <!---Code for Geo location redirect ends here--->


<script>
  (() => {
    const bubble = document.getElementById('cart-icon-bubble');
    const visual = document.getElementById('cart-icon-bubble-visual');
    const countEl = visual ? visual.querySelector('.header__icon-circle-count') : null;
    if (!bubble || !visual || !countEl) return;

    const parseCount = (text) => {
      const match = text.match(/\((\d+)\)/) || text.match(/\b(\d+)\b/);
      return match ? match[1] : '';
    };

    const updateCount = () => {
      const count = parseCount(bubble.textContent || '');
      if (count && count !== '0') {
        countEl.textContent = count;
        countEl.style.display = 'inline-flex';
        countEl.style.borderRadius = count.length <= 2 ? '999px' : '6px';
        if (count.length <= 2) {
          countEl.style.width = '20px';
          countEl.style.height = '20px';
          countEl.style.padding = '0';
        } else {
          countEl.style.width = 'auto';
          countEl.style.height = 'auto';
          countEl.style.padding = '4px 6px';
        }
      } else {
        countEl.textContent = '';
        countEl.style.display = 'none';
      }
    };

    updateCount();
    const observer = new MutationObserver(updateCount);
    observer.observe(bubble, { childList: true, characterData: true, subtree: true });

    visual.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      bubble.click();
    });
  })();
</script>


