<script>
  function callDOMHandler_announcement_bar_new() { 
    var splide = new Splide( '.splide',{
      type   : 'loop',
      pagination: false,
      autoplay: true,
      interval: 5000,
      easing: 'linear'
    });
    splide.on('active', function (slide) {
      var indexLabelEl = splide.root.querySelector('.splide__nav-label')
      var indexLabel = slide.slide.getAttribute('aria-label')
      if (!indexLabelEl || !indexLabel) return
      indexLabelEl.innerHTML = indexLabel.replace(' of ', '/')
    });
    splide.mount();
  }
  if(document.readyState === 'loading') {
    document.addEventListener( 'DOMContentLoaded', callDOMHandler_announcement_bar_new );
  } else {
    callDOMHandler_announcement_bar_new();
  }
</script>
