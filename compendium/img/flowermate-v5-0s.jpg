    <script type="text/javascript">
        jQuery(window).on('load', function() {
            var postClass = '.news-announcement .news-box';

            var thisPost = jQuery(postClass),
                thisEntry = thisPost.find('.entry'),
                thisExcerpt = thisEntry.find('.excerpt');

            thisEntry.stop().animate({
                'bottom': ('-' + thisExcerpt.outerHeight() + 'px')
            }, 400);



            if (jQuery(window).width() > 768) {
                jQuery(postClass).each(function() {
                    var _post = jQuery(this),
                        entry = _post.find('.entry'),
                        postExcerpt = entry.find('.excerpt'),
                        transitionSpeed = 400;

                    if (postExcerpt.css('visibility') == 'hidden') {
                        entry.css({
                            'bottom': ('-' + postExcerpt.outerHeight() + 'px'),
                            'visibility': 'visible'
                        });
                    }
                });

                jQuery(document.body).on('mouseenter', postClass, function(e) {
                    var thisPost = jQuery(e.currentTarget),
                        thisEntry = thisPost.find('.entry');

                    thisEntry.stop().animate({
                        'bottom': 0
                    }, 400);

                }).on('mouseleave', postClass, function(e) {
                    var thisPost = jQuery(e.currentTarget),
                        thisEntry = thisPost.find('.entry'),
                        thisExcerpt = thisEntry.find('.excerpt');

                    thisEntry.stop().animate({
                        'bottom': ('-' + thisExcerpt.outerHeight() + 'px')
                    }, 400);
                });
            } else {
                jQuery(postClass).find('.entry').css({
                    'bottom': 0,
                    'visibility': 'visible'
                });
            }
        });

		jQuery('#main_menu li ul.sub-menu li a img').wrap('<em></em>');

    </script>

